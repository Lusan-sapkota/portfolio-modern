# Backend environment variables
# Admin panel route - change this to keep the admin dashboard hidden
ADMIN_ROUTE=/configure-here

# Token signing key (used to sign session JWTs)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=change-this-in-production

# Admin session expiry in seconds (default 43200 = 12 hours)
# When the session expires, user must re-authenticate with OTP
ADMIN_SESSION_EXPIRY=43200

# GitHub API token (optional, for higher rate limits)
GITHUB_TOKEN=

# Server settings
HOST=0.0.0.0
PORT=8080

# Comma-separated origins allowed to call the API from a browser
# In dev the frontend runs on http://localhost:3000
# Add your production frontend URL when deploying (no trailing slash, no wildcard with credentials)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated IPs of reverse proxies you trust to set X-Forwarded-For
# Leave empty in dev (the rate limiter uses the real TCP peer instead).
# Example: TRUSTED_PROXIES=10.0.0.1,10.0.0.2
TRUSTED_PROXIES=

# Database (PostgreSQL only, no SQLite)
# Free tier: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Email Configuration (for OTP delivery)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=your-email@gmail.com
FROM_NAME=Portfolio Admin

# Admin seed (used ONLY by `make seed` and `make reset-admin`)
# The admin user is created/rotated in the DB with these credentials.
# ADMIN_PASSWORD must NOT be "admin" - if left unset or default, a random
# 24-character password is generated and printed once.
# After the first login, change the password from the admin Settings page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=contact@lusansapkota.com.np
