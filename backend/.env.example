# Backend environment variables
# Admin panel route - change this to keep the admin dashboard hidden
ADMIN_ROUTE=/configure-here

# Admin login credentials (default: admin/admin)
ADMIN_SECRET_KEY=change-this-in-production

# Admin session expiry in seconds (default 43200 = 12 hours)
# When the session expires, user must re-authenticate with OTP
ADMIN_SESSION_EXPIRY=43200

# GitHub API token (optional, for higher rate limits)
GITHUB_TOKEN=

# Server settings
HOST=0.0.0.0
PORT=8080

# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio
# For local development host it in your machine or use neon.tech free tier
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Email Configuration (for contact forms and OTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
# MAIL_FROM is the alias configured in Gmail "Send mail as" settings
MAIL_FROM=your-email@gmail.com
FROM_NAME=Your Name

# Admin Configuration
ADMIN_EMAIL=your-email@gmail.com
